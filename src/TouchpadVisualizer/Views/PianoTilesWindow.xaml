<Window x:Class="TouchpadVisualizer.Views.PianoTilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Piano Tiles"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="Black"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <FontFamily x:Key="GameFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

        <!-- Neon glow colors -->
        <Color x:Key="NeonCyan">#00F5FF</Color>
        <Color x:Key="NeonPurple">#845EF7</Color>
        <Color x:Key="NeonPink">#FF6B9D</Color>
        <Color x:Key="NeonGreen">#39FF14</Color>
        <Color x:Key="NeonRed">#FF1744</Color>
        <Color x:Key="NeonOrange">#FF6B00</Color>
        <Color x:Key="NeonYellow">#FFD600</Color>
        <Color x:Key="DarkSurface">#0A0A0F</Color>

        <!-- Hit zone glow animation -->
        <Storyboard x:Key="HitZonePulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="HitZoneGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.8" Duration="0:0:1.2"
                             AutoReverse="True"
                             EasingFunction="{x:Null}"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Background: pure black with subtle particle canvas -->
        <Canvas x:Name="BackgroundCanvas" Background="#000000" IsHitTestVisible="False"/>

        <!-- Lane separators -->
        <Canvas x:Name="LaneSeparatorCanvas" IsHitTestVisible="False"/>

        <!-- Game tiles canvas -->
        <Canvas x:Name="TileCanvas" IsHitTestVisible="False"/>

        <!-- Hit zone line -->
        <Canvas x:Name="HitZoneCanvas" IsHitTestVisible="False">
            <Border x:Name="HitZoneGlow" Canvas.Left="0" Height="4" Opacity="0.6"
                    CornerRadius="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00845EF7" Offset="0"/>
                        <GradientStop Color="#FF845EF7" Offset="0.2"/>
                        <GradientStop Color="#FF00F5FF" Offset="0.5"/>
                        <GradientStop Color="#FF845EF7" Offset="0.8"/>
                        <GradientStop Color="#00845EF7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <!-- Hit zone area glow -->
            <Border x:Name="HitZoneArea" Canvas.Left="0" Height="80" Opacity="0.08">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#845EF7" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Canvas>

        <!-- Particle effects canvas -->
        <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False"/>

        <!-- Easy Mode waiting indicator -->
        <TextBlock x:Name="WaitingIndicator" Text="▼  TAP THE CORRECT LANE  ▼"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   FontFamily="{StaticResource GameFont}" FontSize="16" FontWeight="SemiBold"
                   Foreground="#39FF14" Opacity="0" Margin="0,0,0,120">
            <TextBlock.Effect>
                <DropShadowEffect Color="{StaticResource NeonGreen}" BlurRadius="15" ShadowDepth="0" Opacity="0.7"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- HUD Overlay -->
        <Grid x:Name="HudGrid" IsHitTestVisible="False">
            <!-- Score display (top center) -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0">
                <TextBlock x:Name="ScoreText" Text="0"
                           Foreground="White" FontFamily="{StaticResource GameFont}"
                           FontSize="48" FontWeight="Bold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="ComboText" Text=""
                           Foreground="#845EF7" FontFamily="{StaticResource GameFont}"
                           FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,-4,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonPurple}" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <!-- Song info (top left) -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,30,0,0">
                <TextBlock x:Name="SongNameText" Text=""
                           Foreground="#80FFFFFF" FontFamily="{StaticResource GameFont}"
                           FontSize="14" FontWeight="Light"/>
                <TextBlock x:Name="SongArtistText" Text=""
                           Foreground="#40FFFFFF" FontFamily="{StaticResource GameFont}"
                           FontSize="11"/>
                <TextBlock x:Name="ModeIndicatorText" Text=""
                           Foreground="#39FF14" FontFamily="{StaticResource GameFont}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,4,0,0" Opacity="0.7"/>
            </StackPanel>

            <!-- Hit quality feedback (center, above hit zone) -->
            <TextBlock x:Name="HitFeedbackText" Text=""
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontFamily="{StaticResource GameFont}" FontSize="36" FontWeight="Bold"
                       Foreground="#00F5FF" Opacity="0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="25" ShadowDepth="0" Opacity="0.8"/>
                </TextBlock.Effect>
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="HitFeedbackScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <!-- Countdown text -->
            <TextBlock x:Name="CountdownText" Text=""
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontFamily="{StaticResource GameFont}" FontSize="120" FontWeight="Bold"
                       Foreground="White" Opacity="0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="{StaticResource NeonPurple}" BlurRadius="40" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Lane key labels (bottom) — dynamically populated in code-behind -->
            <StackPanel x:Name="KeyLabelsPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30"/>

            <!-- ESC hint (top right) -->
            <TextBlock Text="ESC to exit  │  P to pause"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,30,0"
                       Foreground="#25FFFFFF" FontFamily="{StaticResource GameFont}" FontSize="11"/>
        </Grid>

        <!-- Song Selection Menu Overlay -->
        <Grid x:Name="MenuOverlay" Background="#E6000000">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500"
                        Margin="0,60,0,60">
                <!-- Title -->
                <TextBlock Text="♪  PIANO TILES" HorizontalAlignment="Center"
                           FontFamily="{StaticResource GameFont}" FontSize="52" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonPurple}" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Tap the black tiles to the rhythm"
                           HorizontalAlignment="Center" Foreground="#60FFFFFF"
                           FontFamily="{StaticResource GameFont}" FontSize="14" Margin="0,0,0,30"/>

                <!-- ═══ Game Settings ═══ -->
                <Border Padding="20,16" CornerRadius="12" HorizontalAlignment="Center"
                        Margin="0,0,0,24" Width="460">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#845EF7" Opacity="0.1"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="GAME SETTINGS" HorizontalAlignment="Center"
                                   Foreground="#845EF7" FontFamily="{StaticResource GameFont}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <!-- Lane Count Selector -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="LANES" Foreground="#50FFFFFF"
                                       FontFamily="{StaticResource GameFont}" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel x:Name="LaneCountPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Easy Mode Toggle -->
                        <StackPanel Margin="0,0,0,0">
                            <Border x:Name="EasyModeToggle" Padding="14,10" CornerRadius="8"
                                    Cursor="Hand" HorizontalAlignment="Center"
                                    Background="#0AFFFFFF" BorderThickness="1"
                                    MouseLeftButtonDown="EasyModeToggle_Click">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.06"/>
                                </Border.BorderBrush>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="EasyModeIcon" Text="○" Foreground="#50FFFFFF"
                                               FontFamily="{StaticResource GameFont}" FontSize="16"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <StackPanel>
                                        <TextBlock Text="EASY MODE" Foreground="#80FFFFFF"
                                                   FontFamily="{StaticResource GameFont}" FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Tiles wait for your input at the hit zone"
                                                   Foreground="#35FFFFFF" FontFamily="{StaticResource GameFont}"
                                                   FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Song list -->
                <TextBlock Text="SELECT A SONG" HorizontalAlignment="Center"
                           Foreground="#845EF7" FontFamily="{StaticResource GameFont}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <StackPanel x:Name="SongListPanel" Margin="0,0,0,30"/>

                <!-- Controls hint -->
                <Border Padding="16,12" CornerRadius="8" HorizontalAlignment="Center"
                        Background="#10FFFFFF">
                    <StackPanel>
                        <TextBlock Text="CONTROLS" HorizontalAlignment="Center"
                                   Foreground="#50FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="ControlsHintText" Foreground="#40FFFFFF"
                                   FontFamily="{StaticResource GameFont}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <Run Text="Touchpad: tap left/right zones for lanes"/>
                            <LineBreak/>
                            <Run Text="Keyboard: D  F  J  K"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Game Over Overlay -->
        <Grid x:Name="GameOverOverlay" Background="#E6000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
                <TextBlock Text="SONG COMPLETE" HorizontalAlignment="Center"
                           FontFamily="{StaticResource GameFont}" FontSize="36" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,30">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Score -->
                <TextBlock x:Name="FinalScoreText" Text="0" HorizontalAlignment="Center"
                           FontFamily="{StaticResource GameFont}" FontSize="72" FontWeight="Bold"
                           Foreground="#00F5FF">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonCyan}" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="POINTS" HorizontalAlignment="Center"
                           Foreground="#50FFFFFF" FontFamily="{StaticResource GameFont}"
                           FontSize="14" Margin="0,0,0,30"/>

                <!-- Stats -->
                <Border Padding="24,16" CornerRadius="12" HorizontalAlignment="Center"
                        Margin="0,0,0,30">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
                    </Border.Background>
                    <Grid Width="380">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PerfectCountText" Text="0" Grid.Column="0" Grid.Row="0"
                                   Foreground="#00F5FF" FontFamily="{StaticResource GameFont}"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Perfect" Grid.Column="0" Grid.Row="1"
                                   Foreground="#60FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="11" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="GoodCountText" Text="0" Grid.Column="1" Grid.Row="0"
                                   Foreground="#845EF7" FontFamily="{StaticResource GameFont}"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Good" Grid.Column="1" Grid.Row="1"
                                   Foreground="#60FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="11" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="MissCountText" Text="0" Grid.Column="2" Grid.Row="0"
                                   Foreground="#FF1744" FontFamily="{StaticResource GameFont}"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Miss" Grid.Column="2" Grid.Row="1"
                                   Foreground="#60FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="11" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="WrongCountText" Text="0" Grid.Column="3" Grid.Row="0"
                                   Foreground="#FF6B00" FontFamily="{StaticResource GameFont}"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Wrong" Grid.Column="3" Grid.Row="1"
                                   Foreground="#60FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="11" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="MaxComboText" Text="Max Combo: 0" Grid.ColumnSpan="4" Grid.Row="2"
                                   Foreground="#50FFFFFF" FontFamily="{StaticResource GameFont}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="🔄  Replay" Padding="20,10" Margin="0,0,12,0"
                            Click="Replay_Click"
                            Background="#1A845EF7" Foreground="#845EF7" BorderBrush="#30845EF7"
                            BorderThickness="1" FontFamily="{StaticResource GameFont}"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                    <Button Content="📋  Song List" Padding="20,10"
                            Click="BackToMenu_Click"
                            Background="#1AFFFFFF" Foreground="#80FFFFFF" BorderBrush="#20FFFFFF"
                            BorderThickness="1" FontFamily="{StaticResource GameFont}"
                            FontSize="14" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Pause Overlay -->
        <Grid x:Name="PauseOverlay" Background="#CC000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="PAUSED" HorizontalAlignment="Center"
                           FontFamily="{StaticResource GameFont}" FontSize="48" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,20">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{StaticResource NeonPurple}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Press P to resume  │  ESC to quit"
                           HorizontalAlignment="Center" Foreground="#50FFFFFF"
                           FontFamily="{StaticResource GameFont}" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- Lane flash effects (one per lane, overlaid on game area) -->
        <Canvas x:Name="LaneFlashCanvas" IsHitTestVisible="False"/>
    </Grid>
</Window>
