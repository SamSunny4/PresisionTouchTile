<Window x:Class="TouchpadVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Touchpad Visualizer"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Segoe UI Variable / Segoe UI fallback font -->
        <FontFamily x:Key="AppFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

        <!-- Glassmorphism overlay style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#1A1A2E" Opacity="0.85"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3D2C8D" Offset="0"/>
                        <GradientStop Color="#6A3DE8" Offset="0.5"/>
                        <GradientStop Color="#845EF7" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#6A3DE8" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider style -->
        <Style x:Key="NeonSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="#845EF7"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0D0"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- D3D Render Surface -->
        <Image x:Name="RenderImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor">
            <Image.Source>
                <DrawingImage>
                    <DrawingImage.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="Black">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,1920,1080"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingImage.Drawing>
                </DrawingImage>
            </Image.Source>
        </Image>

        <!-- D3DImage will be set programmatically -->
        <Image x:Name="D3DImageHost" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- HUD Overlay -->
        <Grid IsHitTestVisible="False">
            <!-- FPS Counter (top-right) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,20,0" Padding="12,6"
                    Background="#20000000" CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="FpsText" Text="0 FPS"
                               Foreground="#80FFFFFF" FontFamily="{StaticResource AppFont}"
                               FontSize="14" FontWeight="Light"/>
                    <TextBlock Text=" │ " Foreground="#40FFFFFF" FontSize="14"/>
                    <TextBlock x:Name="TouchCountText" Text="0 touches"
                               Foreground="#80FFFFFF" FontFamily="{StaticResource AppFont}"
                               FontSize="14" FontWeight="Light"/>
                </StackPanel>
            </Border>

            <!-- Gesture Indicator (top-center) -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,20,0,0" Padding="16,8"
                    Background="#20000000" CornerRadius="8">
                <TextBlock x:Name="GestureText" Text=""
                           Foreground="#C0845EF7" FontFamily="{StaticResource AppFont}"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Status text (bottom-center) -->
            <TextBlock x:Name="StatusText"
                       Text="Press ESC to exit │ S for settings │ G for Piano Tiles │ F11 fullscreen"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="0,0,0,30"
                       Foreground="#40FFFFFF" FontFamily="{StaticResource AppFont}"
                       FontSize="12" FontWeight="Light"/>

            <!-- Debug Console -->
            <ScrollViewer HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                          Margin="20" Width="400" Height="200" 
                          Background="#88000000" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DebugText" Foreground="#00FF00" FontSize="12" 
                           TextWrapping="Wrap" FontFamily="Consolas" />
            </ScrollViewer>

            <!-- First-launch touchpad gesture hint -->
            <Border x:Name="GestureHintPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24,16" Visibility="Collapsed"
                    Style="{StaticResource GlassPanel}">
                <StackPanel>
                    <TextBlock Text="💡 For best experience"
                               Foreground="#E0E0FF" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Disable Windows touchpad gestures in:"
                               Foreground="#B0B0D0" FontFamily="{StaticResource AppFont}" FontSize="13"/>
                    <TextBlock Text="Settings → Bluetooth &amp; Devices → Touchpad"
                               Foreground="#845EF7" FontFamily="{StaticResource AppFont}" FontSize="13"
                               Margin="0,4,0,8"/>
                    <TextBlock Text="This prevents system gestures from interfering."
                               Foreground="#80808A" FontFamily="{StaticResource AppFont}" FontSize="11"/>
                    <TextBlock Text="Touch the touchpad to dismiss"
                               Foreground="#60607A" FontFamily="{StaticResource AppFont}" FontSize="11"
                               Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Calibration Panel -->
            <Border x:Name="CalibrationPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="32,24" Visibility="Collapsed"
                    Style="{StaticResource GlassPanel}">
                <StackPanel>
                    <TextBlock Text="🎯 Calibrate Touchpad"
                               Foreground="#E0E0FF" FontFamily="{StaticResource AppFont}"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Slide your finger to all four corners of your touchpad"
                               Foreground="#B0B0D0" FontFamily="{StaticResource AppFont}" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="to calibrate the physical edges."
                               Foreground="#B0B0D0" FontFamily="{StaticResource AppFont}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="X Range: " Foreground="#80808A" FontSize="13"/>
                        <TextBlock x:Name="CalibXText" Text="0 - 0" Foreground="#845EF7" FontSize="13" FontWeight="SemiBold" Margin="0,0,16,0"/>
                        <TextBlock Text="Y Range: " Foreground="#80808A" FontSize="13"/>
                        <TextBlock x:Name="CalibYText" Text="0 - 0" Foreground="#845EF7" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Complete" Padding="24,10" Margin="0,0,12,0"
                                Click="CompleteCalibration_Click"
                                Background="#6A3DE8" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="SemiBold"/>
                        <Button Content="Skip" Padding="24,10"
                                Click="SkipCalibration_Click"
                                Background="#2A1A4E" Foreground="#B0B0D0" BorderThickness="0" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Settings Panel (right side) -->
        <Border x:Name="SettingsPanel"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Width="320" Margin="0,0,0,0"
                Visibility="Collapsed"
                IsHitTestVisible="True"
                Style="{StaticResource GlassPanel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="⚙ Settings" Foreground="#E0E0FF"
                               FontFamily="{StaticResource AppFont}" FontSize="20"
                               FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <!-- Quality Preset -->
                    <TextBlock Text="QUALITY PRESET" Style="{StaticResource SettingLabel}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="QualityCombo" Margin="0,4,0,12"
                              SelectedIndex="2" SelectionChanged="QualityCombo_SelectionChanged">
                        <ComboBoxItem Content="Low"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="High"/>
                        <ComboBoxItem Content="Ultra"/>
                    </ComboBox>

                    <!-- FPS Limit -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="FPS Limit: "/><Run x:Name="FpsLimitValue" Text="120"/>
                    </TextBlock>
                    <Slider x:Name="FpsLimitSlider" Minimum="30" Maximum="240" Value="120"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="FpsLimitSlider_ValueChanged"
                            IsSnapToTickEnabled="True" TickFrequency="30"/>

                    <!-- Glow Intensity -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Glow Intensity: "/><Run x:Name="GlowValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="GlowSlider" Minimum="0" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="GlowSlider_ValueChanged"/>

                    <!-- Particle Density -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Particle Density: "/><Run x:Name="DensityValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="DensitySlider" Minimum="10" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="DensitySlider_ValueChanged"/>

                    <!-- Touch Indicator Size -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Indicator Size: "/><Run x:Name="IndicatorValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="IndicatorSlider" Minimum="50" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="IndicatorSlider_ValueChanged"/>

                    <!-- Perspective Angle -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Perspective Angle: "/><Run x:Name="PerspectiveValue" Text="45°"/>
                    </TextBlock>
                    <Slider x:Name="PerspectiveSlider" Minimum="0" Maximum="80" Value="45"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="PerspectiveSlider_ValueChanged"/>

                    <!-- Trail Length -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Trail Length: "/><Run x:Name="TrailValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="TrailSlider" Minimum="0" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="TrailSlider_ValueChanged"/>

                    <!-- Ripple Intensity -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Ripple Intensity: "/><Run x:Name="RippleValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="RippleSlider" Minimum="0" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="RippleSlider_ValueChanged"/>

                    <!-- Background Speed -->
                    <TextBlock Style="{StaticResource SettingLabel}">
                        <Run Text="Background Speed: "/><Run x:Name="BgSpeedValue" Text="1.0"/>
                    </TextBlock>
                    <Slider x:Name="BgSpeedSlider" Minimum="0" Maximum="300" Value="100"
                            Style="{StaticResource NeonSlider}"
                            ValueChanged="BgSpeedSlider_ValueChanged"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                        <Button Content="Save" Padding="16,8" Margin="0,0,8,0"
                                Click="SaveSettings_Click"
                                Background="#3D2C8D" Foreground="White" BorderThickness="0"/>
                        <Button Content="Reset" Padding="16,8"
                                Click="ResetSettings_Click"
                                Background="#2A1A4E" Foreground="#B0B0D0" BorderThickness="0"/>
                    </StackPanel>

                    <Button Content="Calibrate Touchpad" Padding="16,8" Margin="0,12,0,0"
                            Click="StartCalibration_Click"
                            Background="#1A1A2E" Foreground="#845EF7" BorderThickness="1" BorderBrush="#3D2C8D"/>

                    <TextBlock Text="Press S to close" Foreground="#40405A"
                               FontFamily="{StaticResource AppFont}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
